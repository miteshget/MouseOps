# Runtime data — contains live URLs, auth tokens, and user credentials
cis.json
users.json
.secret.key
seq_state.json

# TLS certificates (auto-generated on first run)
.ssl/

# Persisted run logs — contain CI-specific output, not for version control
logs/

# Python
.venv/
__pycache__/
*.pyc

# Node / React build artifacts
frontend/node_modules/
frontend/dist/

# Compiled frontend output (reproduced by bash build.sh)
static/assets/
static/index.html
